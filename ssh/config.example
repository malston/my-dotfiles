# ABOUTME: Example SSH config with common host configurations
# ABOUTME: Copy to ~/.ssh/config and customize as needed

Host *
  IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"

Host github.com
  AddKeysToAgent yes
  IdentityFile ~/.ssh/github_com_rsa

Host gitlab.com
  AddKeysToAgent yes
  IdentityFile ~/.ssh/id_ed25519
